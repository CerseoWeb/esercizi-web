{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react",
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true
  },
  "include": ["app/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
